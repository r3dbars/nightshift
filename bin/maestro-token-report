#!/usr/bin/env python3
import json
import sys
from collections import defaultdict
from pathlib import Path

if len(sys.argv) < 2:
    print("usage: maestro-token-report <run-dir-or-maestro-runs-glob>", file=sys.stderr)
    sys.exit(2)

paths = []
for arg in sys.argv[1:]:
    p = Path(arg).expanduser()
    if p.is_dir() and (p / "meta.json").exists():
        paths.append(p / "meta.json")
    elif p.is_dir():
        paths.extend(sorted(p.glob("*/meta.json")))
    else:
        paths.extend(sorted(Path().glob(str(p))))

totals = defaultdict(lambda: {"calls": 0, "input": 0, "output": 0, "total": 0, "seconds": 0.0})
for path in paths:
    try:
        meta = json.loads(path.read_text())
    except Exception:
        continue
    lane = meta.get("lane", "unknown")
    totals[lane]["calls"] += 1
    totals[lane]["input"] += int(meta.get("prompt_tokens_estimate") or meta.get("input_tokens") or 0)
    totals[lane]["output"] += int(meta.get("output_tokens_estimate") or meta.get("output_tokens") or 0)
    totals[lane]["total"] += int(meta.get("total_tokens_estimate") or meta.get("total_tokens") or 0)
    totals[lane]["seconds"] += float(meta.get("duration_seconds") or 0)

grand = {"calls": 0, "input": 0, "output": 0, "total": 0, "seconds": 0.0}
for lane in sorted(totals):
    row = totals[lane]
    for key in grand:
        grand[key] += row[key]
    print(
        f"{lane}: calls={row['calls']} input≈{row['input']} "
        f"output≈{row['output']} total≈{row['total']} seconds={row['seconds']:.1f}"
    )

print(
    f"TOTAL: calls={grand['calls']} input≈{grand['input']} "
    f"output≈{grand['output']} total≈{grand['total']} seconds={grand['seconds']:.1f}"
)
