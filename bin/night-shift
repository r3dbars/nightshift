def rows_by_name(rows: list[tuple[str, str, str]]) -> dict[str, tuple[str, str]]:
    return {name: (state, message) for name, state, message in rows}


def row_state(rows: list[tuple[str, str, str]], name: str) -> str:
    return rows_by_name(rows).get(name, ("", ""))[0]


def detected_tools(rows: list[tuple[str, str, str]]) -> list[str]:
    by_name = rows_by_name(rows)
    tools = []
    if by_name.get("local-models", ("", ""))[0] == "GREEN" and by_name.get("local-chat", ("", ""))[0] == "GREEN":
        tools.append("local Mac AI")
    if by_name.get("windows-worker", ("", ""))[0] == "GREEN":
        tools.append("another computer")
    if by_name.get("gh-auth", ("", ""))[0] == "GREEN":
        tools.append("GitHub CLI for repo context")
    return tools


def recommended_start_preferences(saved: dict, rows: list[tuple[str, str, str]]) -> dict:
    """Choose safe, useful defaults so the normal setup needs one consent."""
    by_name = rows_by_name(rows)
    github_ready = by_name.get("gh-auth", ("", ""))[0] == "GREEN"
    return {
        "wake_goal": config_value(saved, "wake_goal", "chores"),
        "privacy_route": config_value(saved, "privacy_route", "mac-only"),
        "permission": config_value(saved, "permission", "draft-local"),
        "mode": config_value(saved, "mode", "night-shift"),
        "stop": config_value(saved, "stop", "8h"),
        "scope": configured_scope(saved) if saved else ("github-recent" if github_ready else "current"),
    }


