def stop_deadline(stop_after: str | None) -> float | None:
    seconds = STOP_SECONDS.get(stop_after) if stop_after else None
    return time.time() + seconds if seconds is not None else None


def deadline_reached(deadline: float | None, stop_file: Path | None = None) -> bool:
    reached = deadline is not None and time.time() >= deadline
    if reached and stop_file and not stop_file.exists():
        stop_file.write_text(
            f"automatic stop limit reached at {datetime.now(timezone.utc).isoformat(timespec='seconds')}\n",
            encoding="utf-8",
        )
    return reached

