#!/usr/bin/env bash
set -euo pipefail
model="${MAESTRO_LOCAL_MODEL:-phi-4-mini-instruct}"
base="${MAESTRO_LOCAL_BASE_URL:-http://localhost:1234/v1}"
max_tokens="${MAESTRO_LOCAL_MAX_TOKENS:-512}"
prompt="${*:-}"
if [ -z "$prompt" ]; then
  echo "usage: maestro-local <prompt>" >&2
  exit 2
fi
if ! response="$(curl -fsS --connect-timeout 5 --max-time 180 "$base/chat/completions" \
  -H "Content-Type: application/json" \
  -d "$(python3 - "$model" "$prompt" "$max_tokens" <<'PY'
import json, os, sys
model, prompt, max_tokens = sys.argv[1], sys.argv[2], int(sys.argv[3])
print(json.dumps({"model": model, "messages": [{"role": "user", "content": prompt}], "max_tokens": max_tokens}))
PY
)")"; then
  echo "Mac local AI request failed; I will leave this task untouched." >&2
  exit 1
fi
content="$(python3 - "$response" <<'PY'
import json, os, sys
try:
    data = json.loads(sys.argv[1])
    content = data["choices"][0]["message"]["content"].strip()
    if not content:
        raise ValueError("empty content")
except (KeyError, IndexError, TypeError, ValueError, json.JSONDecodeError):
    print("Mac local AI returned no usable chat content; the response was rejected.", file=sys.stderr)
    raise SystemExit(1)
print(content)
PY
 )" || {
  echo "Mac local AI returned an unreadable response; no draft was kept." >&2
  exit 1
}
printf '%s\n' "$content"
python3 - "$prompt" "$content" "$model" <<'PY'
import json, os, sys
from datetime import datetime, timezone
from pathlib import Path
prompt, content, model = sys.argv[1], sys.argv[2], sys.argv[3]
event = {
    "ts": datetime.now(timezone.utc).isoformat(timespec="seconds"),
    "lane": "local",
    "model": model,
    "message": f"local model call: {model}",
    "input_tokens": max(1, len(prompt)//4),
    "output_tokens": max(1, len(content)//4),
}
event["total_tokens"] = event["input_tokens"] + event["output_tokens"]
codex_home = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex")))
path = codex_home/"maestro-sidecar/events.jsonl"
path.parent.mkdir(parents=True, exist_ok=True)
with path.open("a", encoding="utf-8") as f:
    f.write(json.dumps(event, sort_keys=True)+"\n")
PY
